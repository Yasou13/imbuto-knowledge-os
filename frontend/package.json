{
    "name": "imbuto-knowledge-os",
    "private": true,
    "version": "1.0.0",
    "author": {
        "name": "Yasin",
        "email": "yasinbuyuktepe3@gmail.com"
    },
    "homepage": "https://github.com/Yasou13/Personel-Knowledge-Engine-PKE-",
    "main": "dist-electron/main.js",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:electron": "npm run build && electron-builder --linux",
        "lint": "eslint .",
        "preview": "vite preview"
    },
    "build": {
        "appId": "com.imbuto.knowledge-os",
        "productName": "IMBUTO Knowledge OS",
        "directories": {
            "output": "release"
        },
        "extraResources": [
            {
                "from": "../dist/imbuto_backend",
                "to": "imbuto_backend",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "files": [
            "dist/**/*",
            "dist-electron/**/*"
        ],
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Utility"
        }
    },
    "dependencies": {
        "@codemirror/autocomplete": "^6.20.1",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/language-data": "^6.5.2",
        "@tailwindcss/vite": "^4.2.2",
        "@uiw/codemirror-theme-vscode": "^4.25.9",
        "@uiw/react-codemirror": "^4.25.9",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-force-graph-3d": "^1.29.1",
        "react-router-dom": "^7.14.1",
        "tailwindcss": "^4.2.2",
        "three": "^0.184.0",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.184.0",
        "@vitejs/plugin-react": "^6.0.1",
        "electron": "^41.2.1",
        "electron-builder": "^26.8.1",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.4",
        "vite-plugin-electron": "^0.29.1",
        "vite-plugin-electron-renderer": "^0.14.6"
    }
}